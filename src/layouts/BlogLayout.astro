---
import BaseLayout from './BaseLayout.astro';
import { config } from '../config';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  published: string;
  updated?: string;
  author?: string;
}

const { title, description, keywords, published, updated, author } = Astro.props;
const canonicalUrl = Astro.url.href;
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  canonicalUrl={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "datePublished": published,
    "dateModified": updated || published,
    "author": {
      "@type": "Organization",
      "name": author || config.businessName
    },
    "publisher": {
      "@type": "Organization",
      "name": config.businessName,
      "logo": {
        "@type": "ImageObject",
        "url": "https://parksvillehandyman.ca/logo.png"
      }
    }
  })}></script>

  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Breadcrumb -->
    <nav class="py-6 text-sm text-slate-600">
      <a href="/" class="hover:text-orange-600">Home</a>
      <span class="mx-2">/</span>
      <span>{title.substring(0, 40)}...</span>
    </nav>

    <!-- Article Header -->
    <header class="py-12 border-b border-slate-200">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">{title}</h1>
      <p class="text-lg text-slate-600 mb-6">{description}</p>
      <div class="text-sm text-slate-500">
        <time datetime={published}>{new Date(published).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        {updated && <span class="mx-2">·</span>}
        {updated && <span>Updated <time datetime={updated}>{new Date(updated).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time></span>}
        <span class="mx-2">·</span>
        <span>By {author || config.businessName}</span>
      </div>
    </header>

    <!-- Content -->
    <section class="prose prose-lg max-w-none py-12">
      <slot />
    </section>

    <!-- Author Bio -->
    <section class="bg-slate-50 rounded-lg p-8 my-12 border border-slate-200">
      <h3 class="text-lg font-bold text-slate-900 mb-2">{config.businessName}</h3>
      <p class="text-slate-600">
        Local handyman service serving Parksville, Qualicum Beach, and Oceanside. We fix decks, drywall, gutters, fences, and more. Trusted by Island homeowners since {config.yearEstablished}.
      </p>
      <div class="mt-4">
        <a href="tel:{config.phone}" class="text-orange-600 font-semibold hover:underline">📞 {config.phone}</a>
      </div>
    </section>

    <!-- Related Articles (TODO: dynamic) -->
    <section class="py-12 border-t border-slate-200">
      <h2 class="text-2xl font-bold mb-6">More Articles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <a href="/blog/handyman-vs-contractor" class="border border-slate-200 rounded p-4 hover:border-orange-600 transition">
          <h3 class="font-bold text-slate-900 mb-2">Handyman vs. Contractor: When Do You Need a Licensed Pro?</h3>
          <p class="text-sm text-slate-600">Know the difference before you hire.</p>
        </a>
        <a href="/blog/coastal-deck-damage" class="border border-slate-200 rounded p-4 hover:border-orange-600 transition">
          <h3 class="font-bold text-slate-900 mb-2">How Coastal Weather Destroys Decks</h3>
          <p class="text-sm text-slate-600">Prevention strategies for Island homes.</p>
        </a>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-orange-50 rounded-lg p-8 my-12 text-center">
      <p class="text-lg mb-6">Ready to get your project fixed?</p>
      <a href="tel:{config.phone}" class="inline-block bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 px-8 rounded text-lg">
        📞 Call {config.phone}
      </a>
    </section>
  </article>
</BaseLayout>
