---
import { config } from '../config';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const { title, description, keywords, ogImage, canonicalUrl } = Astro.props;
const fullTitle = `${title} | Parksville Handyman`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}

    <title>{fullTitle}</title>

    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <!-- OpenGraph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={config.businessName} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect fill='%23ea580c' width='100' height='100'/><text x='50' y='65' font-size='70' fill='%23fff' text-anchor='middle' font-weight='bold' font-family='system-ui'>🔧</text></svg>" />

    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        line-height: 1.6;
        color: #1e293b;
        background: #fff;
      }

      a {
        color: #ea580c;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      button, [role="button"] {
        font-family: inherit;
        cursor: pointer;
      }

      img {
        max-width: 100%;
        height: auto;
        display: block;
      }
    </style>
  </head>
  <body>
    <header class="sticky top-0 z-50 bg-white border-b border-slate-200 shadow-sm">
      <nav class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-slate-900 hover:text-orange-600">
          {config.businessName}
        </a>
        <div class="hidden md:flex gap-6 text-sm">
          <a href="/deck-repair" class="hover:text-orange-600">Deck Repair</a>
          <a href="/fence-repair" class="hover:text-orange-600">Fence Repair</a>
          <a href="/gutter-repair" class="hover:text-orange-600">Gutter Cleaning</a>
          <a href="/small-renovations" class="hover:text-orange-600">Odd Jobs</a>
          <a href="/faq" class="hover:text-orange-600">FAQ</a>
          <a href="tel:{config.phone}" class="font-semibold text-orange-600 hover:text-orange-700">{config.phone}</a>
        </div>
        <div class="md:hidden">
          <a href="tel:{config.phone}" class="text-orange-600 font-bold">{config.phone}</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <!-- Sticky mobile CTA -->
    <div class="fixed bottom-0 left-0 right-0 md:hidden bg-orange-600 text-white py-3 px-4 z-40">
      <a href="tel:{config.phone}" class="block text-center font-bold text-lg">
        📞 Call {config.phone}
      </a>
    </div>

    <!-- Add padding to body so sticky button doesn't hide content -->
    <div class="h-16 md:h-0"></div>

    <footer class="bg-slate-900 text-white mt-20 pt-16 pb-8">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
          <div>
            <h3 class="font-bold text-lg mb-4">{config.businessName}</h3>
            <p class="text-slate-300 text-sm">{config.businessName} serves Parksville, Qualicum Beach, and Oceanside with trusted local service since {config.yearEstablished}.</p>
          </div>
          <div>
            <h4 class="font-bold mb-4">Services</h4>
            <ul class="text-sm text-slate-300 space-y-2">
              <li><a href="/deck-repair" class="hover:text-white">Deck Repair</a></li>
              <li><a href="/drywall-repair" class="hover:text-white">Drywall Repair</a></li>
              <li><a href="/fence-repair" class="hover:text-white">Fence Repair</a></li>
              <li><a href="/gutter-repair" class="hover:text-white">Gutter Cleaning</a></li>
              <li><a href="/bathroom-fixtures" class="hover:text-white">Bathroom Fixtures</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-bold mb-4">Areas</h4>
            <ul class="text-sm text-slate-300 space-y-2">
              <li><a href="/parksville" class="hover:text-white">Parksville</a></li>
              <li><a href="/qualicum-beach" class="hover:text-white">Qualicum Beach</a></li>
              <li><a href="/faq" class="hover:text-white">FAQ</a></li>
              <li><a href="/handyman-pricing-bc" class="hover:text-white">Pricing Guide</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-bold mb-4">Contact</h4>
            <p class="text-sm text-slate-300 mb-2">
              <a href="tel:{config.phone}" class="hover:text-white block font-semibold">{config.phone}</a>
            </p>
            <p class="text-sm text-slate-300">
              <a href="mailto:{config.email}" class="hover:text-white">{config.email}</a>
            </p>
            <p class="text-xs text-slate-400 mt-4">Locally operated · Serving the Island since {config.yearEstablished}</p>
          </div>
        </div>
        <div class="border-t border-slate-700 pt-8">
          <p class="text-center text-sm text-slate-400">© {new Date().getFullYear()} {config.businessName}. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
