---
import { config } from '../config';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const { title, description, keywords, ogImage, canonicalUrl } = Astro.props;
const fullTitle = `${title} | Parksville Handyman`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}

    <title>{fullTitle}</title>

    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <!-- OpenGraph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={config.businessName} />
    <meta property="og:url" content={canonicalUrl || Astro.url.href} />
    <meta property="og:image" content={ogImage || 'https://parksvillehandyman.ca/og-default.png'} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={description} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage || 'https://parksvillehandyman.ca/og-default.png'} />
    <meta name="twitter:image:alt" content={description} />

    <!-- Icons & Manifest -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1e293b" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />

    <!-- Turnstile script -->
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

    <!-- GA4 -->
    <script is:inline define:vars={{ gaPropertyId: config.gaPropertyId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gaPropertyId, {
        'anonymize_ip': true,
        'allow_google_signals': false,
        'allow_ad_personalization_signals': false
      });
    </script>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${config.gaPropertyId}`}></script>

    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        line-height: 1.6;
        color: #1e293b;
        background: #fff;
      }

      a {
        color: #ea580c;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      button, [role="button"] {
        font-family: inherit;
        cursor: pointer;
      }

      img {
        max-width: 100%;
        height: auto;
        display: block;
      }

      .cf-turnstile {
        margin: 1rem 0;
      }

      .form-error {
        color: #dc2626;
        font-size: 0.875rem;
        margin-top: 0.25rem;
      }

      .form-success {
        background: #f0fdf4;
        border: 1px solid #86efac;
        color: #166534;
        padding: 1rem;
        border-radius: 0.375rem;
        margin-bottom: 1rem;
      }
    </style>
  </head>
  <body>
    <header class="sticky top-0 z-50 bg-white border-b border-slate-200 shadow-sm">
      <nav class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-slate-900 hover:text-orange-600">
          {config.businessName}
        </a>
        <div class="hidden md:flex gap-6 text-sm">
          <a href="/deck-repair" class="hover:text-orange-600">Deck Repair</a>
          <a href="/fence-repair" class="hover:text-orange-600">Fence Repair</a>
          <a href="/gutter-repair" class="hover:text-orange-600">Gutter Cleaning</a>
          <a href="/small-renovations" class="hover:text-orange-600">Odd Jobs</a>
          <a href="/faq" class="hover:text-orange-600">FAQ</a>
          <a href="tel:{config.phone}" class="font-semibold text-orange-600 hover:text-orange-700">{config.phone}</a>
        </div>
        <div class="md:hidden">
          <a href="tel:{config.phone}" class="text-orange-600 font-bold">{config.phone}</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <!-- Sticky mobile CTA -->
    <div class="fixed bottom-0 left-0 right-0 md:hidden bg-orange-600 text-white py-3 px-4 z-40">
      <a href="tel:{config.phone}" class="block text-center font-bold text-lg">
        📞 Call {config.phone}
      </a>
    </div>

    <!-- Add padding to body so sticky button doesn't hide content -->
    <div class="h-16 md:h-0"></div>

    <footer class="bg-slate-900 text-white mt-20 pt-16 pb-8">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
          <div>
            <h3 class="font-bold text-lg mb-4">{config.businessName}</h3>
            <p class="text-slate-300 text-sm">{config.businessName} serves Parksville, Qualicum Beach, and Oceanside with trusted local service since {config.yearEstablished}.</p>
          </div>
          <div>
            <h4 class="font-bold mb-4">Services</h4>
            <ul class="text-sm text-slate-300 space-y-2">
              <li><a href="/deck-repair" class="hover:text-white">Deck Repair</a></li>
              <li><a href="/drywall-repair" class="hover:text-white">Drywall Repair</a></li>
              <li><a href="/fence-repair" class="hover:text-white">Fence Repair</a></li>
              <li><a href="/gutter-repair" class="hover:text-white">Gutter Cleaning</a></li>
              <li><a href="/bathroom-fixtures" class="hover:text-white">Bathroom Fixtures</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-bold mb-4">Areas</h4>
            <ul class="text-sm text-slate-300 space-y-2">
              <li><a href="/parksville" class="hover:text-white">Parksville</a></li>
              <li><a href="/qualicum-beach" class="hover:text-white">Qualicum Beach</a></li>
              <li><a href="/faq" class="hover:text-white">FAQ</a></li>
              <li><a href="/handyman-pricing-bc" class="hover:text-white">Pricing Guide</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-bold mb-4">Contact</h4>
            <p class="text-sm text-slate-300 mb-2">
              <a href="tel:{config.phone}" class="hover:text-white block font-semibold">{config.phone}</a>
            </p>
            <p class="text-sm text-slate-300">
              <a href="mailto:{config.email}" class="hover:text-white">{config.email}</a>
            </p>
            <p class="text-xs text-slate-400 mt-4">Locally operated · Serving the Island since {config.yearEstablished}</p>
          </div>
        </div>
        <div class="border-t border-slate-700 pt-8">
          <div class="flex flex-wrap justify-center gap-6 mb-4 text-sm text-slate-400">
            <a href="/privacy" class="hover:text-white">Privacy Policy</a>
            <a href="/terms" class="hover:text-white">Terms of Service</a>
            <a href="https://thinkxdesign.com" target="_blank" rel="noopener" class="hover:text-white">Website by Think X Design Media</a>
          </div>
          <p class="text-center text-sm text-slate-400">© {new Date().getFullYear()} {config.businessName}. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
